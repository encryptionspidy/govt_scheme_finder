{
  "env": {
    "browser": false,
    "commonjs": false,
    "es2021": true,
    "node": true
  },
  "extends": ["eslint:recommended", "plugin:import/recommended", "prettier"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "import/no-unresolved": ["error", { "ignore": ["^node:"] }],
    "no-console": "off"
  }
}
