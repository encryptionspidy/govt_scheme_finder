{
  "name": "schemeplus-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env --watch src/server.js",
    "start": "node --env-file=.env src/server.js",
    "lint": "node ./node_modules/eslint/bin/eslint.js \"src/**/*.js\" \"scripts/**/*.js\" \"tests/**/*.js\"",
    "db:init": "node --env-file=.env scripts/init_db.js",
    "db:ingest": "node --env-file=.env scripts/ingest_schemes.js",
    "etl:crawl:myscheme": "node --env-file=.env scripts/myscheme_crawler.js",
    "etl:import:url": "node --env-file=.env scripts/import_public_dataset.js",
    "etl:update": "node --env-file=.env scripts/update_scheme_data.js",
    "data:audit": "node --env-file=.env scripts/data_quality_audit.js",
    "test": "node --test tests/**/*.test.js"
  },
  "dependencies": {
    "axios": "^1.7.4",
    "cheerio": "^1.0.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^7.0.0",
    "morgan": "^1.10.0",
    "node-cache": "^5.1.2",
    "pino": "^9.6.0",
    "pino-http": "^10.3.0",
    "prom-client": "^15.1.3",
    "swagger-ui-express": "^5.0.1",
    "sql.js": "^1.13.0",
    "yamljs": "^0.3.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1"
  }
}
